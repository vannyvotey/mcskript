options:
  cooldown: 5 seconds
  prefix: &x&9&6&0&C&F&6&lᴋ&x&9&6&1&1&E&8&lᴏ&x&9&6&1&6&D&A&lᴍ &x&9&6&2&1&B&E&ls&x&9&6&2&6&B&0&lᴘ&x&9&6&2&B&A&2&lᴀ&x&9&6&3&0&9&4&lᴍ  »&7

on chat:
    # Delete this if statement if you also want to prevent opped players from spamming
    if player is op:
        stop
    if {lastChat.%player%} is not set:
        set {lastChat.%player%} to now
        stop
    if difference between now and {lastChat.%player%} < {@cooldown}:
        cancel event
        set {_remaining} to {@cooldown} - difference between now and {lastChat.%player%}
        send "{@prefix} Please wait another %{_remaining}% between messages!" to player
        stop
    set {lastChat.%player%} to now

on load:
    send "&8&m----------------------------------------" to console
    send "&dScript Author: &fVanny_Chill" to console
    send "&dDiscord: &bhttps://discord.gg/extVWPra" to console
    send "&8&m----------------------------------------" to console
	




















































